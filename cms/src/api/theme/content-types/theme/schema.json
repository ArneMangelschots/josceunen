{
  "kind": "collectionType",
  "collectionName": "themes",
  "info": {
    "singularName": "theme",
    "pluralName": "themes",
    "displayName": "Thema",
    "description": "Tags voor thema's (landschap, portret, …)"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "artworks": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::artwork.artwork",
      "mappedBy": "themes"
    }
  }
}
